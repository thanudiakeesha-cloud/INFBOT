# ── Required for production (Railway / any hosted deployment) ──────────────────

# Set to "production" — enables secure cookies over HTTPS, disables verbose logs
NODE_ENV=production

# Random secret used to sign session cookies (generate a strong random string)
SESSION_SECRET=change-me-to-a-random-secret-string

# ── Firebase (required) ────────────────────────────────────────────────────────
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}   # full JSON, one line

# ── Optional ───────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway — do not set this manually on Railway
# PORT=3000
